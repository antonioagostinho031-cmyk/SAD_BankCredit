# ================================================================
# SAD BankCredit — Backend
# Copie este ficheiro para .env e preencha com os valores reais
# NUNCA commite o ficheiro .env no git
# ================================================================

# ------------------------------------
# Supabase (https://supabase.com)
# Dashboard → Settings → API
# ------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------
# JWT
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------
JWT_SECRET=gerar_um_segredo_longo_e_aleatorio_aqui
JWT_EXPIRATION=7d

# ------------------------------------
# Servidor
# ------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------
# CORS — URL do frontend
# Desenvolvimento: http://localhost:5173
# Produção: https://sad-bankcredit-web.onrender.com (ou domínio personalizado)
# ------------------------------------
FRONTEND_URL=http://localhost:5173

# ------------------------------------
# Armazenamento (Supabase Storage)
# ------------------------------------
STORAGE_BUCKET=documents
MAX_FILE_SIZE=10485760

# ------------------------------------
# Regras de Negócio
# ------------------------------------
MIN_INCOME=50000
MAX_DEBT_RATIO=40
MIN_CREDIT_SCORE=50

# ------------------------------------
# OpenAI (opcional)
# Sem esta chave o sistema usa regras heurísticas para decisão
# ------------------------------------
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-3.5-turbo
